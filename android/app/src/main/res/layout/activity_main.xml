<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DID Wallet"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btn_gen_key"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="1. Generar Par de Claves secp256k1 + DID"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/btn_req_vc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="2. Solicitar Verifiable Credential"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/btn_gen_vp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="3. Generar Verifiable Presentation"
        android:layout_marginBottom="16dp"/>

    <ScrollView
        android:id="@+id/scroll_output"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#F5F5F5">

        <TextView
            android:id="@+id/tv_output"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:fontFamily="monospace"
            android:textSize="11sp"
            android:text="[Output aparecerá aquí]"/>

    </ScrollView>

</LinearLayout>
